@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - SmartLibraryPro</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(rgba(2,6,23,0.92), rgba(2,6,23,0.95)),
            url('https://images.unsplash.com/photo-1524995997946-a1c2e315a42f');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .login-card {
    width: 400px;
    padding: 35px;
    border-radius: 20px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 0 60px rgba(99,102,241,0.3);
    animation: fadeUp 0.6s ease;
}

@@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(40px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

        .form-control {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 12px;
    padding: 12px;
}

.form-control::placeholder {
    color: rgba(255,255,255,0.5);
}

.form-control:focus {
    background: rgba(255,255,255,0.12);
    color: white;
    border: 1px solid #6366f1;
    box-shadow: 0 0 10px rgba(99,102,241,0.6);
}

        .btn-login {
    background: linear-gradient(135deg, #6366f1, #4f46e5);
    border: none;
    padding: 12px;
    border-radius: 25px;
    width: 100%;
    font-weight: 500;
    transition: 0.3s;
}

.btn-login:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(99,102,241,0.8);
}

        .error {
            color: #f87171;
            font-size: 14px;
        }

        .back-btn {
            margin-top: 15px;
            display: block;
            text-align: center;
            color: #cbd5f5;
            text-decoration: none;
        }

        .glow {
    position: absolute;
    width: 400px;
    height: 400px;
    background: #6366f1;
    filter: blur(120px);
    opacity: 0.3;
    top: -100px;
    left: -100px;
}

.glow2 {
    position: absolute;
    width: 350px;
    height: 350px;
    background: #9333ea;
    filter: blur(120px);
    opacity: 0.3;
    bottom: -100px;
    right: -100px;
}
    </style>
</head>

<body>

<div class="glow"></div>
<div class="glow2"></div>

<div class="login-card">

    <h3 class="text-center mb-2">Admin Login</h3>
<p class="text-center" style="opacity:0.6; font-size:14px;">
    Access your library dashboard to manage books, members, and transactions.
</p>

    <form method="post">

        <div class="mb-3">
            <input type="text" name="username" class="form-control" placeholder="Username" required />
        </div>

        <div class="mb-3">
            <input type="password" name="password" class="form-control" placeholder="Password" required />
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error mb-2">@ViewBag.Error</div>
        }

        <button type="submit" class="btn btn-login">Login</button>

        <p style="margin-top:15px; font-size:13px; opacity:0.6; text-align:center;">
         Secure access • Real-time tracking • Smart library management
        </p>

    </form>

    <a href="/Home/Welcome" class="back-btn">Back to Home</a>

</div>

</body>
</html>
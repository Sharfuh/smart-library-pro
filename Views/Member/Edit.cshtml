@model SmartLibraryPro.Models.Member

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Edit Member</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #020617;
            color: white;
        }

        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1497633762265-9d179a990aa6') center/cover no-repeat;
            opacity: 0.05;
            z-index: -1;
        }

        .container-main {
            max-width: 700px;
            margin: auto;
            padding: 40px;
        }

        .glass-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        input {
            background: rgba(255,255,255,0.05) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: white !important;
        }

        input::placeholder {
            color: rgba(255,255,255,0.5);
        }

        label {
            margin-bottom: 5px;
            font-size: 14px;
        }

        .btn-save {
            background: linear-gradient(135deg, #22c55e, #16a34a);
            border: none;
            padding: 10px 22px;
            border-radius: 10px;
            color: white;
            transition: 0.3s;
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(34,197,94,0.4);
        }

        .btn-back {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 10px 22px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-back:hover {
            background: rgba(255,255,255,0.15);
            transform: translateY(-2px);
        }

    </style>
</head>

<body>

<div class="container-main">

    <div class="glass-card">

        <h3>Edit Member</h3>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label>Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Phone</label>
                <input asp-for="Phone" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <input asp-for="Email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Join Date</label>
                <input asp-for="JoinDate" type="date" class="form-control" required />
            </div>

            <div class="mt-4 d-flex gap-3">
                <button type="submit" class="btn-save">Save Changes</button>
                <a href="/Member/Index" class="btn-back">Back</a>
            </div>

        </form>

    </div>

</div>

</body>
</html>
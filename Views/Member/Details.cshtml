@model SmartLibraryPro.Models.Member

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Member Details</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #020617;
            color: white;
        }

        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1492724441997-5dc865305da7') center/cover no-repeat;
            opacity: 0.05;
            z-index: -1;
        }

        .container-main {
            max-width: 900px;
            margin: auto;
            padding: 40px;
        }

        .glass-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .title {
            font-size: 26px;
            font-weight: 600;
        }

        .sub {
            opacity: 0.6;
            margin-bottom: 20px;
        }

        .info-row {
            margin-bottom: 12px;
        }

        .label {
            opacity: 0.6;
            font-size: 13px;
        }

        .value {
            font-size: 15px;
        }

        .btn-edit {
            background: linear-gradient(135deg, #f59e0b, #f97316);
            padding: 10px 20px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(249,115,22,0.4);
        }

        .btn-back {
            background: rgba(255,255,255,0.08);
            padding: 10px 20px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-back:hover {
            background: rgba(255,255,255,0.15);
            transform: translateY(-2px);
        }

    </style>
</head>

<body>

<div class="container-main">

    <div class="glass-card">

        <div class="title">@Model.Name</div>
        <div class="sub">Member Profile</div>

        <div class="info-row">
            <div class="label">Email</div>
            <div class="value">@Model.Email</div>
        </div>

        <div class="info-row">
            <div class="label">Phone</div>
            <div class="value">@Model.Phone</div>
        </div>

        <div class="info-row">
            <div class="label">Join Date</div>
            <div class="value">@Model.JoinDate.ToShortDateString()</div>
        </div>

        <!-- ACTIONS -->
        <div class="mt-4 d-flex gap-3">
            <a href="/Member/Edit/@Model.Id" class="btn-edit">Edit</a>
            <a href="/Member/Index" class="btn-back">Back</a>
        </div>

    </div>

</div>

</body>
</html>
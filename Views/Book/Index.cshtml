@model IEnumerable<SmartLibraryPro.Models.Book>

@{
    Layout = null;

    var total = Model.Count();
    var available = Model.Sum(b => b.AvailableQuantity);
    var issued = Model.Sum(b => b.Quantity - b.AvailableQuantity);
}

<!DOCTYPE html>
<html>
<head>
    <title>Books</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #0b1120;
            color: white;
        }

        /* BACKGROUND */
        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1524995997946-a1c2e315a42f') center/cover no-repeat;
            opacity: 0.08;
            z-index: -1;
        }

        .container-main {
            padding: 30px;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-add {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            color: white;
        }

        .btn-back {
            background: #1f2937;
            padding: 8px 15px;
            border-radius: 8px;
            color: white;
            text-decoration: none;
        }

        /* SUMMARY CARDS */
        .summary-card {
            background: rgba(255,255,255,0.04);
            border-radius: 14px;
            padding: 20px;
            text-align: center;
        }

        /* GRID */
        .grid {
            margin-top: 25px;
        }

        .book-card {
            background: #111827;
            border-radius: 14px;
            overflow: hidden;
            transition: 0.3s;
            position: relative;
        }

        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(99,102,241,0.3);
        }

        .book-img {
            height: 180px;
            background-size: cover;
            background-position: center;
        }

        .book-body {
            padding: 15px;
        }

        .book-title {
            font-weight: 600;
        }

        .book-author {
            font-size: 13px;
            color: #9ca3af;
        }

        .status {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .available { background: #16a34a; }
        .issued { background: #f59e0b; }
        .out { background: #ef4444; }

        .actions {
    margin-top: 12px;
    display: flex;
    gap: 8px;
}

    

        .btn-sm {
            flex: 1;
        }

        /* EMPTY STATE */
        .empty {
            text-align: center;
            margin-top: 60px;
            opacity: 0.7;
        }

        /* INFO PANEL */
        .info-panel {
            margin-top: 40px;
            background: rgba(255,255,255,0.04);
            padding: 25px;
            border-radius: 14px;
        }
        .sub-text {
    font-size: 14px;
    color: #9ca3af;
    margin-top: 5px;
}
/* GLASS BUTTON */
.btn-glass {
    padding: 10px 18px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.25s ease;
    font-weight: 500;
}

.btn-glass:hover {
    background: rgba(255,255,255,0.12);
    transform: translateY(-2px);
}

/* GRADIENT BUTTON */
.btn-gradient {
    padding: 10px 22px;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    font-weight: 500;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    box-shadow: 0 6px 20px rgba(99,102,241,0.35);
    transition: all 0.25s ease;
}

.btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(168,85,247,0.55);
}
.book-img {
    height: 180px;
    background-size: cover;
    background-position: center;
    transition: 0.3s;
}

.book-card:hover .book-img {
    transform: scale(1.1);
}
.desc {
    font-size: 12px;
    opacity: 0.7;
    margin-top: 6px;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;

    transition: 0.3s;
}
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
}

.modal-box {
    background: #111827;
    padding: 25px;
    border-radius: 14px;
    width: 300px;
    text-align: center;
}

.modal-actions {
    display: flex;
    justify-content: center;  /* 🔥 center align */
    gap: 15px;
    margin-top: 20px;
}

/* DELETE BUTTON */
.btn-delete {
    background: #ef4444;
    padding: 10px 20px;
    border-radius: 10px;
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

/* 🔥 HOVER */
.btn-delete:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(239,68,68,0.4);
}

/* CANCEL BUTTON */
.btn-cancel {
    background: #374151;
    padding: 10px 20px;
    border-radius: 10px;
    color: white;
    border: none;
    transition: 0.3s;
}

/* 🔥 HOVER */
.btn-cancel:hover {
    background: #4b5563;
    transform: translateY(-2px);
}
.form-control, .form-select {
    background: rgba(255,255,255,0.08);
    color: white;
    border: none;
}

.form-control::placeholder {
    color: #aaa;
}

/* 🔍 SEARCH INPUT */
.form-control {
    background: rgba(255,255,255,0.06);
    color: #ffffff !important;   /* FORCE WHITE TEXT */
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 10px 14px;
    transition: 0.3s;
}

/* Placeholder */
.form-control::placeholder {
    color: #9ca3af;
}

/* Focus */
.form-control:focus {
    border-color: #6366f1;
    box-shadow: 0 0 12px rgba(99,102,241,0.6);
    background: rgba(255,255,255,0.08);
    outline: none;
    color: #ffffff !important
}

/* 🎯 SELECT DROPDOWN */
/* 🌟 GLASS DROPDOWN */
.form-select {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 14px;

    padding: 10px 16px;
    font-weight: 500;

    transition: all 0.3s ease;

    appearance: none;

    /* Glow */
    box-shadow: 0 0 10px rgba(99,102,241,0.15);

    background-image: url("data:image/svg+xml,%3Csvg fill='white' viewBox='0 0 20 20'%3E%3Cpath d='M5 7l5 5 5-5H5z'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 14px;
}
.form-select:hover {
    border-color: rgba(99,102,241,0.6);
    box-shadow: 0 0 15px rgba(99,102,241,0.4);
}

/* Dropdown focus */
.form-select:focus {
    outline: none;
    border-color: #6366f1;

    box-shadow:
        0 0 12px rgba(99,102,241,0.8),
        0 0 25px rgba(99,102,241,0.4);

    background: rgba(255, 255, 255, 0.12);
}

/* FIX DROPDOWN OPTIONS (IMPORTANT) */
select option {
    background: #020617;
    color: #ffffff;
}

    </style>
</head>

<body>

<div class="container-main">

    <!-- HEADER -->
    <div class="header mb-4">
    <div>
        <h2>Library Inventory</h2>
        <p class="sub-text">Manage and monitor all books in your system</p>
    </div>

    <div class="d-flex gap-3">

        <a href="/Dashboard/Index" class="btn-glass">
            Back to Dashboard
        </a>

        <a href="/Book/Create" class="btn-gradient">
            Add Book
        </a>

    </div>
</div>

<div class="d-flex gap-3 mb-4">

    <!-- SEARCH -->
    <input type="text" id="bookSearch" placeholder="Search books..."
           onkeyup="filterBooks()" class="form-control" style="max-width:250px;" />

    <!-- CATEGORY -->
    <select id="categoryFilter" onchange="filterBooks()" class="form-select" style="max-width:200px;">
        <option value="">All Categories</option>
        <option>Fiction</option>
        <option>Science</option>
        <option>Technology</option>
        <option>History</option>
        <option>Biography</option>
        <option>Business</option>
        <option>Self Development</option>
        <option>Education</option>
        <option>Comics</option>
        <option>Philosophy</option>
    </select>

    <!-- STATUS -->
    <select id="statusFilter" onchange="filterBooks()" class="form-select" style="max-width:200px;">
        <option value="">All Status</option>
        <option value="available">Available</option>
        <option value="issued">Issued</option>
        <option value="out">Out of Stock</option>
    </select>

</div>

    <!-- GRID -->
    <div class="row g-4 grid">

        @if (!Model.Any())
        {
            <div class="empty">
                <h4>No Books Added Yet</h4>
                <p>Start by adding books to manage your library.</p>
            </div>
        }
        else
        {
            foreach (var book in Model)
            {
                var status = book.AvailableQuantity == 0 ? "Out of Stock"
                            : book.AvailableQuantity < book.Quantity ? "Issued"
                            : "Available";

                var statusClass = status == "Available" ? "available"
                                  : status == "Issued" ? "issued"
                                  : "out";

                <div class="col-md-3 book-card-wrapper"
     data-title="@book.Title.ToLower()"
     data-category="@book.Category.ToLower()"
     data-status="@(book.AvailableQuantity == 0 ? "out" : book.AvailableQuantity < book.Quantity ? "issued" : "available")">
                    <div class="book-card">

                        <div class="book-img"
                             style="background-image:url('@(string.IsNullOrEmpty(book.ImagePath) ? "https://via.placeholder.com/300" : book.ImagePath)')">
                        </div>

                        <div class="status @statusClass">@status</div>

                        <div class="book-body">
    <div class="book-title">@book.Title</div>
    <div class="book-author">@book.Author</div>

    <div class="desc">@book.Description</div>

    <div class="actions">
        <a href="/Book/Details/@book.Id" class="btn btn-primary btn-sm">View</a>
        <a href="/Book/Edit/@book.Id" class="btn btn-warning btn-sm">Edit</a>
        <button class="btn btn-danger btn-sm"onclick="openDeleteModal('/Book/Delete/@book.Id')">Delete</button>
    </div>
</div>

                    </div>
                </div>
            }
        }

    </div>

    <div id="noBookResult" class="text-center mt-4 d-none">
    <h5>No books found</h5>
    <p style="opacity:0.6;">Try different filters</p>
</div>

    <!-- INFO PANEL -->
    <div class="info-panel">
        <h5>📘 About Book Management</h5>
        <p>
            This section allows you to manage all books in the library.
            You can add, update, and track book availability.
        </p>

        <ul>
            <li>Available books decrease when issued</li>
            <li>Out of stock when quantity reaches zero</li>
            <li>Issued books are tracked in transactions</li>
            <li>Ensure proper stock management</li>
        </ul>
    </div>

</div>
<script>
function openDeleteModal(deleteUrl) {
    document.getElementById("deleteModal").classList.remove("d-none");
    document.getElementById("confirmDeleteBtn").href = deleteUrl;
}

function closeModal() {
    document.getElementById("deleteModal").classList.add("d-none");
}


function filterBooks() {

    let search = document.getElementById("bookSearch").value.toLowerCase();
    let category = document.getElementById("categoryFilter").value.toLowerCase();
    let status = document.getElementById("statusFilter").value;

    let cards = document.querySelectorAll(".book-card-wrapper");
    let found = false;

    cards.forEach(card => {

        let title = card.getAttribute("data-title");
        let cat = card.getAttribute("data-category");
        let stat = card.getAttribute("data-status");

        let match =
            title.includes(search) &&
            (category === "" || cat === category) &&
            (status === "" || stat === status);

        if (match) {
            card.style.display = "block";
            found = true;
        } else {
            card.style.display = "none";
        }

    });

    let noResult = document.getElementById("noBookResult");

    if (!found) {
        noResult.classList.remove("d-none");
    } else {
        noResult.classList.add("d-none");
    }
}

</script>

<!-- DELETE MODAL -->
<div id="deleteModal" class="modal-overlay d-none">
    <div class="modal-box">
        <h5>Confirm Delete</h5>
        <p>Are you sure you want to delete this book?</p>

        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <a id="confirmDeleteBtn" class="btn-delete">Delete</a>
        </div>
    </div>
</div>

</body>
</html>
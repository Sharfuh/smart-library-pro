@model SmartLibraryPro.Models.Book

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Add Book</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #0b1120;
            color: white;
        }

        /* BACKGROUND */
        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1512820790803-83ca734da794') center/cover no-repeat;
            opacity: 0.08;
            z-index: -1;
        }

        .container-main {
            max-width: 800px;
            margin: auto;
            padding: 40px 20px;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-glass {
            padding: 10px 18px;
            border-radius: 12px;
            text-decoration: none;
            color: white;
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.08);
        }

        /* FORM CARD */
        .form-card {
            margin-top: 25px;
            padding: 30px;
            border-radius: 16px;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
        }

        .form-control {
            background: rgba(255,255,255,0.06);
            border: none;
            color: white;
            border-radius: 10px;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.08);
            color: white;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.5);
        }

        label {
            margin-bottom: 5px;
            font-size: 14px;
        }

        /* BUTTON */
        .btn-submit {
            margin-top: 15px;
            padding: 12px;
            width: 100%;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            color: white;
            font-weight: 500;
            transition: 0.3s;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
        }

        /* IMAGE PREVIEW */
        .preview {
            margin-top: 10px;
            height: 150px;
            border-radius: 10px;
            background-size: cover;
            background-position: center;
        }
        .custom-select {
         background: rgba(255,255,255,0.06);
         color: white;
         border-radius: 10px;
         border: none;
        }

        /* Fix dropdown options */
         .custom-select option {
          background: #111827;
          color: white;
         }
         .preview-container {
    display: flex;
    justify-content: center;
    margin-top: 15px;
}

.preview {
    width: 120px;
    height: 160px;
    border-radius: 10px;
    background-size: cover;
    background-position: center;
    transition: 0.3s;
    cursor: pointer;
}

/* HOVER ZOOM */
.preview:hover {
    transform: scale(2);
    z-index: 10;
}
/* REMOVE NUMBER INPUT ARROWS */

/* Chrome, Edge, Safari */
input[type=number]::-webkit-inner-spin-button,
input[type=number]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

/* Firefox */
input[type=number] {
    -moz-appearance: textfield;
}
input[type=number] {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
}

    </style>
</head>

<body>

<div class="container-main">

    <!-- HEADER -->
    <div class="header">
        <h2>Add New Book</h2>
        <a href="/Book/Index" class="btn-glass">Back</a>
    </div>

    <!-- FORM -->
    <div class="form-card">

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="mb-3">
                <label>Title</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Author</label>
                <input asp-for="Author" class="form-control" required />
            </div>

            <div class="mb-3">
              <label>Category</label>
                <select asp-for="Category" class="form-control custom-select">
                   <option>Fiction</option>
                   <option>Science</option>
                   <option>Technology</option>
                   <option>History</option>
                   <option>Biography</option>
                   <option>Business</option>
                   <option>Self Development</option>
                   <option>Education</option>
                   <option>Comics</option>
                   <option>Philosophy</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Quantity</label>
                <input asp-for="Quantity" type="number" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                  placeholder="Enter short description about the book..."></textarea>
            </div>

            <div class="mb-3">
                <label>Upload Image</label>
                <input type="file" name="imageFile" class="form-control" onchange="previewImage(event)" />
                <div class="preview-container">
                <div id="preview" class="preview"></div>
                </div>
            </div>

            <button type="submit" class="btn-submit">Create Book</button>

        </form>

    </div>

</div>

<script>
    function previewImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            document.getElementById('preview').style.backgroundImage = "url(" + reader.result + ")";
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

</body>
</html>
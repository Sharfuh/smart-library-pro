@model SmartLibraryPro.Models.Book

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit Book</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(to right, #020617, #020617);
            color: white;
        }

        .container-main {
            max-width: 700px;
            margin: auto;
            padding: 40px;
        }

        .glass-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        input, textarea, select {
            background: rgba(255,255,255,0.05) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: white !important;
        }

        input::placeholder, textarea::placeholder {
            color: rgba(255,255,255,0.5);
        }

        .btn-save {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    border: none;
    padding: 10px 22px;
    border-radius: 10px;
    color: white;
    transition: 0.3s;
}

/* 🔥 HOVER */
.btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(34,197,94,0.4);
}

        .btn-back {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 10px 22px;
    border-radius: 10px;
    color: white;
    transition: 0.3s;
}
/* 🔥 HOVER */
.btn-back:hover {
    background: rgba(255,255,255,0.15);
    transform: translateY(-2px);
}

        .preview {
            width: 140px;
            height: 180px;
            border-radius: 10px;
            background-size: cover;
            background-position: center;
            margin-top: 10px;
        }

        /* remove arrows */
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type=number] {
            -moz-appearance: textfield;
        }

        .preview-container {
    display: flex;
    justify-content: center;
    margin-top: 15px;
}

.preview {
    width: 140px;
    height: 180px;
    border-radius: 10px;
    background-size: cover;
    background-position: center;
    transition: 0.3s;
    cursor: pointer;
}

/* 🔥 HOVER ZOOM */
.preview:hover {
    transform: scale(1.5);
}

    </style>
</head>

<body>

<div class="container-main">

    <div class="glass-card">

        <h3>Edit Book</h3>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label>Title</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Author</label>
                <input asp-for="Author" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Category</label>
                <select asp-for="Category" class="form-control">
                    <option>Fiction</option>
                    <option>Non-Fiction</option>
                    <option>Science</option>
                    <option>Technology</option>
                    <option>Business</option>
                    <option>History</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Quantity</label>
                <input asp-for="Quantity" type="number" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <!-- IMAGE -->
            <div class="mb-3">
                <label>Upload New Image</label>
                <input type="file" name="imageFile" class="form-control" onchange="previewImage(event)" />
                
                <div class="preview-container">
                <div id="preview"
                  class="preview"
                     style="background-image:url('@Model.ImagePath')">
                 </div>
                 </div>
            </div>

            <div class="mt-4 d-flex gap-3">
                <button type="submit" class="btn-save">Save Changes</button>
                <button href="/Book/Index" class="btn-back">Back</button>
            </div>

        </form>

    </div>

</div>

<script>
    function previewImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            document.getElementById('preview').style.backgroundImage =
                "url('" + reader.result + "')";
        };
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

</body>
</html>
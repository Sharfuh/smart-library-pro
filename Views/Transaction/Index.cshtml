@model IEnumerable<SmartLibraryPro.Models.Transaction>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Transactions</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #020617;
            color: white;
            font-family: 'Inter', sans-serif;
        }

        .container-main {
            padding: 30px;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-glass {
            padding: 10px 20px;
            border-radius: 12px;
            background: rgba(255,255,255,0.08);
            color: white;
            text-decoration: none;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }

        .btn-glass:hover {
            background: rgba(255,255,255,0.15);
            transform: translateY(-2px);
        }

        .btn-gradient {
            padding: 10px 20px;
            border-radius: 12px;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(168,85,247,0.4);
        }

        /* TABLE */
        .table-box {
            margin-top: 25px;
            background: rgba(255,255,255,0.04);
            border-radius: 14px;
            overflow: hidden;
        }

        table {
            width: 100%;
        }

        th {
            background: rgba(255,255,255,0.08);
            padding: 12px;
        }

        td {
            padding: 12px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }

        /* STATUS */
        .status {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .issued { background: #f59e0b; }
        .returned { background: #16a34a; }
        .overdue { background: #ef4444; }

        /* ACTION */
        .btn-return {
            padding: 6px 12px;
            border-radius: 10px;
            background: #22c55e;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-return:hover {
            background: #16a34a;
            transform: scale(1.05);
        }

        /* OVERDUE ROW */
        .row-overdue {
            background: rgba(239,68,68,0.08);
        }

        .search-box input {
    width: 300px;
    padding: 10px 14px;
    border-radius: 12px;
    border: none;
    outline: none;
    background: rgba(255,255,255,0.08);
    color: white;
}

.search-box input::placeholder {
    color: #9ca3af;
}

.form-control {
    background: rgba(255, 255, 255, 0.08) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);

    color: #ffffff !important;
    font-weight: 500;

    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px;

    padding: 10px 14px;
    transition: all 0.3s ease;
}

/* Typing color */
.form-control:focus {
    color: #ffffff !important;
    background: rgba(255,255,255,0.10) !important;

    border-color: #6366f1;

    box-shadow:
        0 0 12px rgba(99,102,241,0.7),
        0 0 25px rgba(99,102,241,0.4);

    outline: none;
}

/* Placeholder */
.form-control::placeholder {
    color: #9ca3af;
}
.form-select {
    background: rgba(255, 255, 255, 0.08) !important;
    backdrop-filter: blur(12px);

    color: #ffffff !important;
    font-weight: 500;

    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px;

    padding: 10px 16px;
    transition: all 0.3s ease;

    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg fill='white' viewBox='0 0 20 20'%3E%3Cpath d='M5 7l5 5 5-5H5z'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 14px;
}

.form-select:hover {
    border-color: rgba(99,102,241,0.6);
    box-shadow: 0 0 15px rgba(99,102,241,0.4);
}

.form-select:focus {
    background: rgba(255,255,255,0.10) !important;
    color: #ffffff !important;

    border-color: #6366f1;

    box-shadow:
        0 0 12px rgba(99,102,241,0.7),
        0 0 25px rgba(99,102,241,0.4);

    outline: none;
}
select option {
    background: #020617 !important;
    color: #ffffff !important;
}
    </style>
</head>

<body>

<div class="container-main">

    <!-- HEADER -->
    <div class="header">
        <div>
            <h2>Transactions</h2>
            <p style="opacity:0.6;">Track issued and returned books</p>
        </div>

        <div class="d-flex gap-3">
            <a href="/Dashboard/Index" class="btn-glass">Back to Dashboard</a>
            <a href="/Transaction/Issue" class="btn-gradient">Issue Book</a>
        </div>
    </div>

<div class="d-flex gap-3 mb-4 flex-wrap">

    <!-- SEARCH -->
    <input type="text" id="transactionSearch"
           placeholder="Search by member..."
           onkeyup="filterTransactions()" class="form-control"
           style="max-width:250px;" />

    <!-- STATUS FILTER -->
    <select id="statusFilter" onchange="filterTransactions()" class="form-select" style="max-width:200px;">
        <option value="">All Status</option>
        <option value="issued">Issued</option>
        <option value="returned">Returned</option>
        <option value="overdue">Overdue</option>
    </select>

    <!-- OVERDUE QUICK FILTER -->
    <select id="overdueFilter" onchange="filterTransactions()" class="form-select" style="max-width:200px;">
        <option value="">All Records</option>
        <option value="yes">Only Overdue</option>
    </select>

</div>

    <!-- TABLE -->
    <div class="table-box">
        <table>
            <thead>
                <tr>
                    <th>Book</th>
                    <th>Member</th>
                    <th>Issue Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th>Fine</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var t in Model)
                {
                    var isOverdue = t.ReturnDate == null && t.DueDate < DateTime.Now;

                    var status = t.ReturnDate != null ? "Returned"
                                : isOverdue ? "Overdue"
                                : "Issued";

                    var statusClass = status == "Returned" ? "returned"
                                      : status == "Overdue" ? "overdue"
                                      : "issued";

                    <tr class="transaction-row @(isOverdue ? "row-overdue" : "")"
    data-member="@t.Member?.Name.ToLower()"
    data-status="@(t.ReturnDate != null ? "returned" : isOverdue ? "overdue" : "issued")"
    data-overdue="@(isOverdue ? "yes" : "no")">
                        <td>@t.Book?.Title</td>
                        <td>@t.Member?.Name</td>
                        <td>@t.IssueDate.ToShortDateString()</td>
                        <td>@t.DueDate.ToShortDateString()</td>
                        <td>@(t.ReturnDate?.ToShortDateString() ?? "-")</td>
                        <td>₹@t.Fine</td>

                        <td>
                            <span class="status @statusClass">@status</span>
                        </td>

                        <td>
                            @if (t.ReturnDate == null)
                            {
                                <a href="/Transaction/Return/@t.Id" class="btn-return">
                                    Return
                                </a>
                            }
                            else
                            {
                                <span style="opacity:0.6;">Completed</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="noTransactionResult" class="text-center mt-4 d-none">
    <h5>No transactions found</h5>
    <p style="opacity:0.6;">Try adjusting filters</p>
</div>

</div>

<script>
function filterTransactions() {

    let search = document.getElementById("transactionSearch").value.toLowerCase();
    let status = document.getElementById("statusFilter").value;
    let overdue = document.getElementById("overdueFilter").value;

    let rows = document.querySelectorAll(".transaction-row");
    let found = false;

    rows.forEach(row => {

        let name = row.getAttribute("data-member") || "";
        let rowStatus = row.getAttribute("data-status");
        let rowOverdue = row.getAttribute("data-overdue");

        let match =
            name.includes(search) &&
            (status === "" || rowStatus === status) &&
            (overdue === "" || rowOverdue === overdue);

        if (match) {
            row.style.display = "";
            found = true;
        } else {
            row.style.display = "none";
        }

    });

    let noResult = document.getElementById("noTransactionResult");

    if (!found) {
        noResult.classList.remove("d-none");
    } else {
        noResult.classList.add("d-none");
    }
}
</script>

</body>
</html>